# Flask Secret Key for session signatures
SECRET_KEY=dev-secret-key-1293847

# Database Connection String (fallback is local app.db SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/cloud_intelligence

# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Slack Webhook Integration (for critical notifications dispatch)
SLACK_WEBHOOK_URL=https://example.com/slack-webhook-placeholder

# SMTP Email Dispatch Server Credentials (optional alerts fallback)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=alerts@yourdomain.com
EMAIL_PASSWORD=your_smtp_app_password
